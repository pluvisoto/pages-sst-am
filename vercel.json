{
  "buildCommand": "node generate-env.js",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/landingpage", "destination": "/landingpage.html" },
    { "source": "/contadores", "destination": "/contadores.html" },
    { "source": "/parceiros", "destination": "/contadores.html" },
    { "source": "/", "destination": "/landingpage.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/am-logo-branca.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
